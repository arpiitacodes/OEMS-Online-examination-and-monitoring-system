# ── OEMS environment template ──
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` — it is gitignored.

# Flask session signing key. Generate a new one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-64-char-hex-string

# MySQL database
DB_HOST=localhost
DB_USER=root
DB_PASS=your-database-password
DB_NAME=exam_system

# Gmail SMTP for welcome / OTP emails.
# Use a Google "App Password" (not your account password).
OEMS_EMAIL=your-email@gmail.com
OEMS_EMAIL_PASSWORD=your-16-char-app-password

# Misc
GRPC_DNS_RESOLVER=native
CAMPUS_IP_RANGES=10.0.0
SBERT_MODEL=all-MiniLM-L6-v2
PLAGIARISM_THRESHOLD=70

# ── Face recognition (ArcFace login) — optional overrides ──
# All have sensible defaults in code; uncomment only to tune.
# FACE_MATCH_THRESHOLD=0.42        # cosine match cutoff (higher = stricter)
# FACE_DUPLICATE_THRESHOLD=0.55    # blocks one face on two accounts
# FACE_LIVENESS_CHALLENGE=any      # any | blink | turn
# FACE_VERIFY_FRAMES=4             # clean frames averaged per login
# FACE_REGISTER_FRAMES=6           # clean frames averaged on first setup
# FACE_MODEL_PACK=buffalo_l        # InsightFace model pack
# FACE_AUTH_WINDOW_SECONDS=600     # how long the face step stays valid after password
